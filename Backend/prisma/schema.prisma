generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // url removed - now in prisma.config.js
}

//////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////

enum Role {
  ATTENDEE
  SPEAKER
  ADMIN
}

enum TShirtSize {
  XS
  S
  M
  L
  XL
  XXL
}

enum SpeakerStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SponsorStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CertificateStatus {
  NOT_GENERATED
  GENERATED
  SENT
  FAILED
}

enum EmailStatus {
  DRAFT
  SENT
  FAILED
  PARTIAL
}

enum EmailTarget {
  ATTENDEES
  SPEAKERS
  BOTH
  CUSTOM
}

enum SponsorTier {
  GOLD
  SILVER
  COMMUNITY
}

enum AgendaTrack {
  MAIN_STAGE
  WORKSHOP
  PANEL
  NETWORKING
  OPENING
  CLOSING
}

enum SpeakerTrack {
  CLOUD_FUNDAMENTALS
  DEVOPS
  AI_ML
  SECURITY
  OPEN_SOURCE
}

enum ExperienceLevel {
  ZERO_TO_ONE
  ONE_TO_THREE
  THREE_TO_FIVE
  FIVE_PLUS
}

//////////////////////////////////////////////////
// MODELS
//////////////////////////////////////////////////

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String?
  role         Role     @default(ATTENDEE)
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  attendee Attendee?
  speaker  Speaker?
  admin    Admin?
  sessions Session[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique @default(cuid())
  expiresAt DateTime
  createdAt DateTime @default(now())
  ipAddress String?
  userAgent String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("sessions")
}

model Admin {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admins")
}

model Attendee {
  id           String     @id @default(cuid())
  userId       String     @unique
  university   String
  phone        String?
  tshirtSize   TShirtSize
  checkedIn    Boolean    @default(false)
  checkedInAt  DateTime?
  registeredAt DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  hasPaid      Boolean    @default(false)

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  swag        SwagRecord?
  certificate Certificate?
  payments    Payment[]

  @@index([checkedIn])
  @@map("attendees")
}

model SwagRecord {
  id         String   @id @default(cuid())
  attendeeId String   @unique
  tshirt     Boolean  @default(false)
  stickers   Boolean  @default(false)
  notebook   Boolean  @default(false)
  badge      Boolean  @default(false)
  pen        Boolean  @default(false)
  wristband  Boolean  @default(false)
  updatedAt  DateTime @updatedAt
  updatedBy  String?

  attendee Attendee @relation(fields: [attendeeId], references: [id], onDelete: Cascade)

  @@map("swag_records")
}

